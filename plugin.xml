<?xml version="1.0" encoding="UTF-8"?>
<plugin xmlns="http://apache.org/cordova/ns/plugins/1.0"
        xmlns:android="http://schemas.android.com/apk/res/android"
        id="cordova-plugin-firebasex-functions"
        version="1.0.0">

    <name>cordova-plugin-firebasex-functions</name>
    <description>Firebase Cloud Functions module for cordova-plugin-firebasex</description>
    <license>MIT</license>
    <keywords>cordova,firebase,functions,cloud functions</keywords>

    <engines>
        <engine name="cordova" version=">=12.0.0" />
        <engine name="cordova-android" version=">=14.0.0" />
        <engine name="cordova-ios" version=">=7.0.0" />
    </engines>

    <dependency id="cordova-plugin-firebasex-core" />

    <js-module src="www/firebasex-functions.js" name="FirebasexFunctionsPlugin">
        <clobbers target="FirebasexFunctionsPlugin" />
    </js-module>

    <!-- Android -->
    <platform name="android">
        <config-file target="config.xml" parent="/*">
            <feature name="FirebasexFunctionsPlugin">
                <param name="android-package" value="org.apache.cordova.firebasex.FirebasexFunctionsPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>

        <framework src="src/android/build.gradle" custom="true" type="gradleReference" />
        <source-file src="src/android/FirebasexFunctionsPlugin.java"
                     target-dir="src/org/apache/cordova/firebasex" />
    </platform>

    <!-- iOS -->
    <platform name="ios">
        <config-file target="config.xml" parent="/*">
            <feature name="FirebasexFunctionsPlugin">
                <param name="ios-package" value="FirebasexFunctionsPlugin" />
                <param name="onload" value="true" />
            </feature>
        </config-file>

        <header-file src="src/ios/FirebasexFunctionsPlugin.h" />
        <source-file src="src/ios/FirebasexFunctionsPlugin.m" />

        <podspec>
            <config>
                <source url="https://cdn.cocoapods.org/" />
            </config>
            <pods use-frameworks="true">
                <pod name="FirebaseFunctions" spec="12.9.0"/>
            </pods>
        </podspec>
    </platform>

</plugin>
